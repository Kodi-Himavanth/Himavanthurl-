<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <style>
        body{
            font-family: 'Courier New', Courier, monospace ;
        }
    </style>
</head>
<body>
    <!-- MODIFIED: Completely removed the old 'urls' loop block to prevent ReferenceErrors -->
    
    <h1>URL Shortener</h1>
    <% if (locals.id) { %>
     <!-- MODIFIED: Fixed the port typo from 8000 to 8001 to match your index.js server config -->
     <p> URL Generated: http://localhost:8001/<%= id %></p>
    <% } %>
    
    <form method="POST" action="/url">
        <label for="">Enter Your Original URL</label>
        <input type="text"
         name="url"
        placeholder="http://example.com">
        <button type="submit">Generate</button>
    </form>
    <div>
       
        <% if (locals.urls) { %>
           <table border="1"> 
            <thead>
                <tr> 
                    <th>s.No</th>
                    <th>ShortID</th>
                    <th>Redirect</th>
                    <th>Clicks</th>
                </tr>
            </thead>
            <tbody>
                <% locals.urls.forEach((url, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                 
                  <td><%= url.shortId %></td>
                  <td><%= url.redirectURL %></td>
                 
                  <td><%= url.visitHistory ? url.visitHistory.length : 0 %></td>
                </tr>
                <% }) %>
            </tbody>
           </table>
        <% } %>
    </div>
</body>

</html>